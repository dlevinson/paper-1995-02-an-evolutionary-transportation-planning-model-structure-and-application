#  program to go through scenarios 1 by 1 (year by year)set emme2=/trn2/users/emme2/rel6/etc/emme2set macros=/trn2/mnt/macros/travel2set returnTo = $cwdset netfiles = $returnTo/netfilesset stepsize=1#set iterate=1990#    cp landuse/reg/d311.$iterate d311.in#    $emme2 311 clear batch #    cp landuse/mc/d311.$iterate d311.in#    $emme2 311 clear batch #    cp landuse/demo/d311.ages.$iterate d311.in#    $emme2 311 clear batch#    cp landuse/demo/d311.hhsize.$iterate d311.in#    $emme2 311 clear batch #travel2ampm $iterate a > foo$iterate#rm foo$iterate# program to go through scenarios 1 by 1 (year by year)set iterate=1999set redist=0.225set limit=2000while ( $iterate <= $limit )   $emme2 clear batch -m "$macros/t.scenario $iterate"############### initialize modes & vehicles###############   $emme2 clear 201 batch -m "$macros/t.b201"#   $emme2 clear 202 batch -m "$macros/t.b202"############### initialize nodes & links###############  cp $netfiles/d211.$iterate $returnTo/d211.in#  $emme2 clear 211 batch############### initialize node specfic boarding times###############  $emme2 clear 241 batch -m "$macros/t.boardbatch"############### initialize transit lines###############  cp $netfiles/d221.$iterate.pm $returnTo/d221.in#  $emme2 clear 221 batch############### initialize turns###############  initturn $iterate###############  copy landuse and demographics for year##############   cp landuse/reg/d311.$iterate d311.in   $emme2 311 clear batch    cp landuse/mc/d311.$iterate d311.in   $emme2 311 clear batch    cp landuse/demo/d311.ages.$iterate d311.in   $emme2 311 clear batch   cp landuse/demo/d311.hhsize.$iterate d311.in   $emme2 311 clear batch ###############  Store last years trip gen for work trips##############   $emme2 clear 321 batch -m "$macros/t.holdtrip"###############  RUN TRIPGEN for this year##############  $emme2 clear 321 batch -m "$macros/t.3dtripgenpm"   $emme2 clear 321 batch -m "$macros/t.baltimorepm" ###############  Compute fractionally new trips (this year - last year + redist)##############   $emme2 clear 321 batch -m "$macros/t.fractrip $redist"###############  Redistribute (321 & 322)##############   $emme2 clear batch -m "$macros/t.redist"###############  SUM WORK TRIPS into mf27 & mf28##############   $emme2 clear 321 batch -m "$macros/t.dynasum $redist"   $emme2 clear 321 batch -m "$macros/t.sumaodpm $iterate"###############  RUN MODEL##############  dyna2e $iterate a > foo$iterate  rm foo$iterate  @ iterate = $iterate + $stepsize  endexit