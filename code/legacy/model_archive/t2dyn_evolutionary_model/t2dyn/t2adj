##################################################################################                                                                            ### travel2    : c-shell script to execute TRAVEL/2                              ##              release 2                                                       ##                                                                              ## by David Levinson                                                            ##                                                                              ## date of last update: 02/16/93                                                ##                                                                              ## usage: travel2     SSSS R > & fooSSSS &                                      ##                                                                              ## where: SSSS = 4 digit network scenario number                                ##           R = n letter matrix run  identifier                                ##                                                                              ###                                                                            ##################################################################################set echoset whoami=`whoami`cat $0################################################################################## Set EMME/2 Release Number: Release 6################################################################################set emme2=/trn2/users/emme2/rel6/etc/emme2################################################################################## Set Model Parameters################################################################################set master=$1set run=$2set scendum=1######################## model (am/pm)#######################set model=pm######################## year (1980-2020)#######################set year=2000######################## iterate,lambda  (0-99)#######################set iterate=1set lambda=$iterate######################## previter (0-99)#######################set previter=1######################## stepsize (1-9)#######################set stepsize=1########################  limit (0-99)#######################set limit=30######################## netset (yes,no)#######################set netset=yes######################## turnset (yes,no)#######################set turnset=yes######################## loop (open,closed)#######################set loop=open######################## doclose (yes,no)#######################set doclose=no######################## converged (yes/no)#######################set converged="no"######################## dothisloop,restart (yes/no)#######################set dothisloop=noset restart="no"################################################################################## Set Model Components######################################################################################################## auto ownership (yes/no)#######################set autoown=no######################## trip generation (yes/no)#######################set generation=no######################## mode choice (static/no) (no "elastic" - not convex!)#######################set modechoice=no######################## departure time choice (elastic/vda/no)#######################set timechoice=no######################## multimodal distribution (elastic/no)#######################set destchoice=no######################## Auto (SOV) Assignment (elastic/vda/traversal/select/skimlength/#                        hovrun/calibrate/no)#######################set assignment=elastic######################## HOV Submodels (true,elastic,static,no)# (true is true hovrun on hov network)# (elastic & static use modified SOV times)#######################set hovrun=elastic######################## allowable class on HOV (2,3)#######################set hovclass=2######################## Transit Modal Time Skim Submodels (elastic/static/no)#######################set wctskim=noset actskim=no######################## If ACT Skim - Get Mode Transfer Facility (yes/no)#######################set mtfskim=no######################## Auto Demand (elastic/static/no)#######################if ($timechoice == "elastic" || $modechoice == "elastic" || $destchoice == "elastic") then   set demand="elastic"else   set demand="static"endif######################## Walk Connect Transit Demand (yes/no)#######################set wctdemand=no######################## Auto Connect Transit Demand (elastic/static/yes/no)#######################set actdemand=no######################## HOV Demand (elastic/no)#######################set hovdemand=no######################## Traversal Demand (work/nonwork/transit/total/no)#######################set travdem=no######################## How to Iterate #######################set thisiter=7######################## Assignment Submodels # intersect  (elastic,static,no)#######################set intersect=elastic######################## Set Plots (yes/no)#######################set pltdff=noset pltcap=noset pltffs=noset pltspd=noset pltcfr=noset pltclv=noset pltvcr=yesset pltlan=yesset plttrn=no######################## Set Default Window for Plots (a-z)#######################set window=z######################## Calibration Routines (yes/no)#######################set exautocal=noset screenline=noset outerloop=1set callimit=1set netcal=no################################################################################# Set Additional Scenarios###############################################################################set scensov=$masterif ( $assignment == "calibrate" ) then  set scendem=2else  set scendem=$scensovendif################################################################################# Set Paths ###############################################################################set returnTo = $cwdset macros="/trn2/mnt/macros/travel2"set bin="/trn2/mnt/Mtools/Ttools/bin"set tmp="/tmp"set source="/trn2/mnt/Mtools/Ttools/source"set tcounts="/trn2/mnt/Mtools/Ttools/tcounts"set configure="$returnTo/configure"set autonet="/trn2/mnt/Mtools/Ttools/autonet"set ensemble="/trn2/mnt/Mtools/Ttools/ensemble"set rf="$returnTo/rf$master$run$model"set rfsp="$returnTo/rf$master$run$model/secplan"################################################################################# Set Filenames###############################################################################set autocal="$autonet/d241.newcal2"set nodezone="$autonet/nodezone"set nodename="$autonet/nodename"set polcap="$autonet/d241.polcap"set delay="$autonet/delay3"set reverse="$autonet/d241.reverse"set tzconfig="$ensemble/tzconfig.t2"set spconfig="$ensemble/tzconfig.sp"set geoconfig="$ensemble/geoconfig"set prconfig="$configure/d241.prconfig.$year"set turnlanes="$configure/lanes.in.$year"set turnpro="$configure/d231.$year"set traversal="$configure/d241.traverse"set select="$configure/d241.select"set takeaway="$configure/d241.takeaway"set intcap="$configure/d241.intcap"set stfile="$configure/d241.stfile"######################## Calibration Files (filename)#######################set countsfile=nocountsset speedsfile=nospeeds################################################################################ start model set up, static operations###############################################################################if ( $iterate == "1" ) then################################################################################# Setup RunFile###############################################################################if ( -e $rf) then  rm -fr $rfendifmkdir $rfmkdir $rfsprm errorstouch errorscp $0 $rf################################################################################# Prepare module parameters###############################################################################$emme2 clear batch -m "$macros/t.scenario $scensov"$emme2 clear batch -m "$macros/t.switches"$emme2 clear 212 batch -m "$macros/t.modpar212"$emme2 clear 213 batch -m "$macros/t.modpar213"$emme2 clear 313 batch -m "$macros/t.modpar313"$emme2 clear 314 batch -m "$macros/t.modpar314"$emme2 clear 316 batch -m "$macros/t.modpar316"$emme2 clear 322 batch -m "$macros/t.modpar322"$emme2 clear 413 batch -m "$macros/t.modpar413"$emme2 clear 213 batch -m "$macros/t.window"##$emme2 clear 534 batch -m "$macros/t.modpar534"##$emme2 clear 535 batch -m "$macros/t.modpar535"## execute only if auto assignment done on this scenario#$emme2 clear 611 batch -m "$macros/t.modpar611"#$emme2 clear 612 batch -m "$macros/t.modpar612"#$emme2 clear 613 batch -m "$macros/t.modpar613"#$emme2 clear 614 batch -m "$macros/t.modpar614"#$emme2 clear 615 batch -m "$macros/t.modpar615"## execute only if transit assignment done on this scenario#$emme2 clear 621 batch -m "$macros/t.modpar621"#$emme2 clear 622 batch -m "$macros/t.modpar622"#$emme2 clear 623 batch -m "$macros/t.modpar623"################################################################################## Create Scenarios###############################################################################if ( $intersect != "no" ) then   $emme2 clear 122 batch -m "$macros/t.createscen $master $scendum DUMMY"endifif ( $netcal == "yes" ) then   $emme2 clear 122 batch -m "$macros/t.createscen $master $scendem CALIBRATION"endif###################################### TRANSPOSE MATRICES ####################################$emme2 clear 321 batch -m "$macros/t.transmat $year"###################################### Landuse REPORTS####################################$emme2 clear 314 batch -m "$macros/t.plateLU"awk -f $source/aggregatorLU.a $returnTo/reports $tzconfig > $rf/rep.LU$masterawk -f $source/aggregatorLU.a $returnTo/reports $spconfig > $rfsp/rep.LU$master###################################### AUTO OWNERSHIP MODEL####################################if ($autoown == "yes") then $emme2 clear 321 batch -m "$macros/t.autoown" $emme2 clear 314 batch -m "$macros/t.plateAO" awk -f $source/aggregatorAO.a $returnTo/reports $tzconfig > $rf/rep.AO$master awk -f $source/aggregatorAO.a $returnTo/reports $spconfig > $rfsp/rep.AO$masterendif################################################################################# TRIP GENERATION###############################################################################if ($generation == "yes") then  $emme2 clear 321 batch -m "$macros/t.3dtripgen$model"   $emme2 clear 321 batch -m "$macros/t.baltimore$model"   if ($model == "am") then   $emme2 clear 314 batch -m "$macros/t.plateTGam"   awk -f $source/aggregatorTG1.a $returnTo/reports $tzconfig > $rf/rep.TG$1   awk -f $source/aggregatorTG1.a $returnTo/reports $spconfig > $rfsp/rep.TG$1sp  else if ($model == "pm") then   $emme2 clear 314 batch -m "$macros/t.plateTGopm"   mv $returnTo/reports $rf/rep.TGo2   $emme2 clear 314 batch -m "$macros/t.plateTGdpm"   mv $returnTo/reports $rf/rep.TGd2   paste $rf/rep.TGo2 $rf/rep.TGd2 > $rf/rep.TG2   awk -f $source/aggregatorTG2.a $rf/rep.TG2 $tzconfig > $rf/rep.TG$1   awk -f $source/aggregatorTG2.a $rf/rep.TG2 $spconfig > $rfsp/rep.TG$1sp   rm $rf/rep.TGo2 $rf/rep.TGd2 $rf/rep.TG2  endifendif################################################################################# Define Network############################################################################################################ Define PM network###########################if ($model == "pm") then   cp $reverse $returnTo/d241.in   $emme2 clear 241 batch -m "$macros/t.reverse"endif############################# Define Volume Delay Functions## NOTE: Use Fixed VDFs for time being (DML 7.13.92)###########################if ($netset == "yes") then   rm $returnTo/d241.in   touch $returnTo/d241.in   $emme2 clear 241 batch -m "$macros/t.startvdf"endif##########################################################    $emme2 clear batch -m "$macros/t.scenario $scendem"#     $emme2 clear 241 batch -m "$macros/t.startcap"#    $emme2 clear batch -m "$macros/t.scenario $scensov"#     $emme2 clear 241 batch -m "$macros/t.startcap"##########################################################  cp $autocal $returnTo/d241.in#  cp $autocal $rf#  $emme2 clear 241 batch -m "$macros/t.newervdf2"################################################################################# Initialize Turn Penalties ###############################################################################if ($turnset == "yes") then   awk -f $source/makedeftl.a $turnlanes > $returnTo/d231.in   $bin/idelay9 $nodename $turnlanes $returnTo/d231.in $intcap   if ($status != 0) then          banner "FAILED"          banner "IDELAY"          echo   "iteration $iterate"          goto exeunt   endif   awk -f $source/postidel.a $returnTo/d231.out > $returnTo/d231.in3   awk -f $source/nozero.a $returnTo/d231.in3 > $returnTo/d231.in2   sort -n +1 -2 +2 -3 +3 -4 $returnTo/d231.in2 > $rf/d231.in   awk -f $source/mfile.a $returnTo/d231.in2 > $returnTo/d231.in1   echo "t turns init" > $returnTo/d231.in   awk '{ if ( $1 != "t" ) {print $1,$2,$3,$4,"0 1 1 1"}}' $turnpro >> $returnTo/d231.in1   sort -n +1 -2 +2 -3 +3 -4 $returnTo/d231.in1 >> $returnTo/d231.in   $emme2 clear 231 batch -m "$macros/t.clear231"   mv reports $rf/rep.turnpen   mv $returnTo/d231.out $rf   rm $returnTo/d231.in3 $returnTo/d231.in2 $returnTo/d231.in1################################################################################## for Dummy Scenario Initialize Turn Penalties###############################################################################   $emme2 clear batch -m "$macros/t.scenario $scendum"     $emme2 clear 231 batch -m "$macros/t.clear231"     $emme2 clear 511 batch -m "$macros/t.511dummy"   $emme2 clear batch -m "$macros/t.scenario $scensov"endif################################################################################# INITIAL ALL OR NOTHING AUTO ASSIGNMENT for elastic demand###############################################################################if ($demand == "elastic") then   if ( $hovrun != "true") then      $emme2 clear 511 batch -m "$macros/t.511AoNpm"   else if ( $hovrun == "true") then      $emme2 clear 511 batch -m "$macros/t.511AoNmc"   endif   $emme2 clear 521 batch   if ($status != 0) then          banner "FAILED"          banner "ASSIGNMENT"          echo   "iteration $iterate"          goto exeunt   endif   mv $returnTo/reports $rf/rep.521dd   $emme2 clear 321 batch -m "$macros/t.timeaddAoN$model"   if ( $hovrun != "true") then      $emme2 clear 321 batch -m "$macros/t.timehovAoN"   else if ( $hovrun == "true") then      $emme2 clear 321 batch -m "$macros/t.timehovAoNmc"   endif   $emme2 clear 511 batch -m "$macros/t.511transit ms02"   $emme2 clear 531 batchendif################################################################################ end (if (iterate == "1" ) then)###############################################################################endif################################################################################# BEGIN OUTER LOOP (Calibration)###############################################################################while ( $outerloop <= $callimit )################################################################################# BEGIN INNER LOOP (Model)###############################################################################while ( $iterate <= $limit )  if ( $loop == "open" ) then################################################################################# MODE TIME SKIMS (auto assignment must be done first!)################################################################################################################ High Occupancy Vehicle "Skim"## (uses auto assignment in mf16)###############################   if ( $hovrun == "elastic" || ( $hovrun == "static" && $thisiter == $iterate )) then      $emme2 clear 321 batch -m "$macros/t.hovskim"   endif################################# auto connect skim ## (uses auto assignment in mf16)###############################   if ( $actskim == "elastic" || ( $actskim == "static" && $thisiter == $iterate )) then################################# auto connect transit in-use test###############################set locktest=1test:     if ( -e $tmp/.lockm) then       @ locktest = $locktest + 1       sleep 360       if ( $locktest > 20 ) then	  banner "LOCK"	  banner "MODECHAIN"	  echo "in $tmp subdirectory"	  echo "for more than 120 minutes"	  echo "-------------------------"	  cat $tmp/.lockm	  echo "-------------------------"	  echo "exiting"	  goto exeunt        endif       goto test     else 	who am i > $tmp/.lockm        rm $tmp/skim.IJ $tmp/skim.JK $tmp/d311.mf36 	rm $tmp/d311.mf41 $tmp/d311.mf42################################# auto connect transit subskim###############################      $emme2 clear 201 batch -m "$macros/t.modmodev 60"      $emme2 clear 511 batch -m "$macros/t.511transit ms02"      $emme2 clear 531 batch      if ($status != 0) then        banner "FAILED"        banner "TRANSIT"	banner "ACT SKIM"        echo   "iteration $iterate"        goto exeunt      endif      mv $returnTo/reports $rf/rep.531act      $emme2 clear 201 batch -m "$macros/t.modmodev 3"################################# auto connect transit outputs###############################        $emme2 clear 314 batch -m "$macros/t.actaskimout"        mv $returnTo/reports $tmp/skim.IJ        $emme2 clear 314 batch -m "$macros/t.acttskimout"        mv $returnTo/reports $tmp/skim.JK        $bin/modechainpm $prconfig $tmp/skim.IJ $tmp/skim.JK $mtfskim        if ($status != 0) then          banner "FAILED"          banner "MODECHAIN"          echo   "iteration $iterate"          goto exeunt        endif        $emme2 clear batch -m "$macros/t.batchin $tmp/d311.mf36"        rm $tmp/skim.IJ $tmp/skim.JK $tmp/d311.mf36         if ($mtfskim == "yes") then          $emme2 clear batch -m "$macros/t.batchin $tmp/d311.mf41"          $emme2 clear batch -m "$macros/t.batchin $tmp/d311.mf42"	  rm $tmp/d311.mf41 $tmp/d311.mf42        endif	rm $tmp/.lockm      endif    endif################################# Walk Connect Transit skim###############################   if ( $wctskim == "elastic" || ( $wctskim == "static" && $thisiter == $iterate )) then      $emme2 clear 511 batch -m "$macros/t.511transit ms02"      $emme2 clear 531 batch      if ($status != 0) then        banner "FAILED"        banner "TRANSIT SKIM"        echo   "iteration $iterate"        goto exeunt      endif      mv reports $rf/rep.531    endif################################################################################# MODE CHOICE - LOGIT STATIC ###############################################################################   if (( $modechoice == "static" && $thisiter == $iterate )) then    if ( $year == "1989" ) then      $emme2 clear 321 batch -m "$macros/t.year89"    endif    $emme2 clear 321 batch -m "$macros/t.modechoice2$model $hovclass"   endif################################################################################# DESTINATION CHOICE: GRAVITY ELASTIC###############################################################################   if ( $destchoice == "elastic" && $converged != "yes" ) then#     $emme2 clear batch -m "$macros/t.anndist $iterate $hovclass"      $emme2 clear batch -m "$macros/t.destination2$model $iterate $hovclass" #     $emme2 clear batch -m "$macros/t.adjfac   endif################################################################################# DEPARTURE TIME CHOICE - LOGIT ELASTIC###############################################################################   if ( $timechoice == "elastic" && $converged != "yes" ) then       $emme2 clear 321 batch -m "$macros/t.timechoice$model mf16"   endif################################################################################# Determine Auto Connect to Transit TRIP TABLES###############################################################################  if ($actdemand == "elastic" || ( $actdemand == "static" && $thisiter == $iterate )) thentest2:     if ( -e $tmp/.lockm) then       sleep 360       goto test2     else       who am i > $tmp/.lockm      $emme2 clear 321 batch -m "$macros/t.adtdemand"      $emme2 clear 314 batch -m "$macros/t.punchpark"      rm $tmp/d311.mf35 $tmp/d311.mf23 $tmp/d311.mf45      $bin/parkrestrain $prconfig $returnTo/reports      mv $returnTo/zonesummaries $rf      mv $returnTo/parksummaries $rf      $emme2 clear batch -m "$macros/t.batchin $tmp/d311.mf35"      $emme2 clear batch -m "$macros/t.batchin $tmp/d311.mf23"      $emme2 clear batch -m "$macros/t.batchin $tmp/d311.mf45"      rm $tmp/d311.mf35 $tmp/d311.mf23 $tmp/d311.mf45      $emme2 clear 321 batch -m "$macros/t.aptdemand"      $emme2 clear 314 batch -m "$macros/t.punchkiss"      rm $tmp/d311.mf45      $bin/kissassign $returnTo/reports       $emme2 clear batch -m "$macros/t.batchin $tmp/d311.mf45"      rm $tmp/d311.mf45      rm $tmp/.lockm    endif  endif################################################################################# SUM PEAK HOUR TRIP TABLES - (ANY DEMAND IS ELASTIC)###############################################################################if ($converged != "yes" ) then  if ( $hovrun != "true" && $timechoice != "vda" &&  $demand == "elastic" ) then    $emme2 clear 321 batch -m "$macros/t.sumaod$model $iterate"  else if ( $hovrun != "true" && $timechoice == "vda" &&  $demand == "elastic" ) then    $emme2 clear 321 batch -m "$macros/t.sumvda$model $iterate"  else if ( $hovrun == "true" ) then    $emme2 clear 321 batch -m "$macros/t.sumsov$hovclass$model $iterate"    if ( $hovdemand != "no" ) then      $emme2 clear 321 batch -m "$macros/t.sumhov$hovclass$model $iterate"    endif  endif endif################################################################################# WHICH TRAVERSAL###############################################################################  if ( $demand == "elastic" || ( $demand == "static" && $iterate <= 2 )) then   if ( $assignment == "traversal" && $travdem == "work" ) then      $emme2 clear 321 batch -m "$macros/t.sumpkwork $iterate"   else if ( $assignment == "traversal" && $travdem == "nonwork" ) then      $emme2 clear 321 batch -m "$macros/t.sumpknonw $iterate"   else if ( $assignment == "traversal" && $travdem == "transit" ) then      $emme2 clear 321 batch -m "$macros/t.trantable$model $iterate"   else if ( $assignment == "traversal" && $travdem == "total" ) then      $emme2 clear 321 batch -m "$macros/t.sumpktot $iterate"   endif  endif################################################################################# ENDIF - LOOP = "OPEN"###############################################################################endif################################################################################# FINAL ITERATION OF AUTO ASSIGNMENT BEFORE REPORTS###############################################################################if (( $iterate == $limit || $converged == "yes" ) && $demand == "elastic" ) then  if ( $dothisloop == "yes" ) then    $emme2 clear 321 batch -m "$macros/t.fixdem"    cp $rf/d231.in $rf/d231.inold    cp $rf/d231.last $rf/d231.in    @ limit = $limit + 10    set lambda="1"    set converged="yes"    set doclose="no"    set dothisloop="no"  endifendif################################################################################# ROUTE CHOICE: STATIC USER EQUILIBRIUM ASSIGNMENT###############################################################################  if ( $iterate == "1" || $restart == "yes" ) then       if ($assignment == "traversal") then         cp $traversal d241.in         $emme2 clear 241 batch -m "$macros/t.traverse"         $emme2 clear 511 batch -m "$macros/t.511TRVw$model $iterate mf38"       else if ($assignment == "select") then         cp $select d241.in         $emme2 clear 241 batch -m "$macros/t.traverse"         $emme2 clear 511 batch -m "$macros/t.511sel$model $iterate mf38"       else if ($assignment == "skimlength") then          $emme2 clear 511 batch -m "$macros/t.511EQU$model $iterate"       else if ($assignment == "elastic" ) then          $emme2 clear 511 batch -m "$macros/t.511EQUn$model $iterate"       else if ($assignment == "calibrate" ) then         if ($netcal == "network" ) then          $emme2 clear 511 batch -m "$macros/t.capadj1 $iterate"         else if ($netcal == "matrix" ) then          $emme2 clear 511 batch -m "$macros/t.capadj1x $iterate"         endif       else if ($assignment == "hovrun" && $hovrun == "true" ) then          $emme2 clear 511 batch -m "$macros/t.511mclass $iterate"       else if ($assignment == "vda") then          $emme2 clear 511 batch -m "$macros/t.vda511n$model $iterate"       endif       if ($assignment != "no") then         $emme2 clear 521 batch         if ($status != 0) then           banner "FAILED"           banner "ASSIGNMENT"           echo   "iteration $iterate"           goto exeunt         endif         cat $returnTo/reports >> $rf/rep.521dd       endif  else if ( $iterate > "1" && $restart != "yes" ) then############################ Intersection Delay Model##########################    if ( $intersect == "elastic" && $assignment != "no" ) then         $emme2 clear 611 batch -m "$macros/t.611int"         if ($status != 0) then          banner "FAILED"          banner "611REPORT"          echo   "nodes: iteration $iterate"          goto exeunt         endif         awk -f $source/prepidel.a $returnTo/reports > $rf/turnvols.i